{
  "expo": {
    "name": "Relicus",
    "slug": "relicus-native",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.relicus.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.relicus.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#FFFFF0"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "87315b77-72b1-4ac6-969d-183ae3dadc1a"
      }
    },
    "owner": "relicus52"
  }
}
